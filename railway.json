{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpkgs": ["python310", "python310Packages.pip"]
        },
        "install": {
          "apk": [],
          "pip": ["-e .", "-e \".[ai-scheduler]\""]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "python main.py"
  }
}
